<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Dashboard de Superhéroes</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-white p-8 flex flex-col items-center">

    <h1 class="text-3xl font-bold text-sky-700 mb-8">Lista de Superhéroes</h1>
    <a href="/dashboard/agregar"><button class="rounded-md px-20 py-2 mb-0 bg-green-400 font-semibold  text-sky-900 shadow-md shadow-gray-500 hover:bg-green-500" > [+]  Agregar Nuevo</button></a>
    
    <table class="w-full max-w-[95%] border border-gray-200 border-collapse shadow-md">
        <thead>
            <tr class="border-b-2 border-sky-200 bg-blue-400">
                <th class="p-3 text-left text-sky-900">Superhéroe</th>
                <th class="p-3 text-left text-sky-900">Nombre Real</th>
                <th class="p-3 text-left text-sky-900">Edad</th>
                <th class="p-3 text-left text-sky-900">Origen</th>
                <th class="p-3 text-left text-sky-900">Poderes</th>
                <th class="p-3 text-left text-sky-900">Debilidad/es</th>
                <th class="p-3 text-left text-sky-900">Aliados</th>
                <th class="p-3 text-left text-sky-900">Enemigos</th></th>
                <th class="p-3 text-center text-sky-900">Acciones</th>
                
            </tr>
        </thead>
        <tbody>
            <% superheroes.forEach(superheroe => { %>
                    <tr class="border-b border-sky-50 hover:bg-sky-100">
                    <td class="p-3"><%= superheroe.nombreSuperHeroe %></td>
                    <td class="p-3 text-gray-600"><%= superheroe.nombreReal %></td>
                    <td class="p-3 text-gray-600"><%= superheroe.edad %></td>
                    <td class="p-3 text-gray-600"><%= superheroe.planetaOrigen %></td>
                    <td class="p-3 text-gray-600"><%= superheroe.poderes %></td>
                    <td class="p-3 text-gray-600"><%= superheroe.debilidad %></td>
                    <td class="p-3 text-gray-600"><%= superheroe.aliados %></td>
                    <td class="p-3 text-gray-600"><%= superheroe.enemigos %></td>
                    <td class="p-3 flex justify-center gap-4">
                    <a href="/dashboard/editar/<%= superheroe.id %>"><button class="text-sky-600 font-semibold hover:underline cursor-pointer">Editar</button></a>
                    <button class="text-red-500 font-semibold hover:underline cursor-pointer" onclick="eliminar('<%= superheroe.id %>', '<%= superheroe.nombreSuperHeroe %>')">Eliminar</button>
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>

    
    <script>
        async function eliminar(id,nombre){
            const confirmar = confirm("¿Seguro de eliminar a '"+nombre+"'?");
            if(!confirmar) return;
            const res = await fetch("api/heroes/" + id, {method: "DELETE"});
            if(res.ok){
                window.location.reload();
            }else{
                alert("Error al eliminar el registro") + (error.message || JSON.stringify(error))
            }
        } 
    </script>

</body>
</html>